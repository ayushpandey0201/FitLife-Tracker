# Copy to .env and adjust. Consumed by pydantic-settings (introduced in Phase 2).
# No secrets are required to run the Phase 1 domain / CLI.

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Database (Phase 3) ---
# DATABASE_URL=postgresql+psycopg://fitlife:fitlife@localhost:5432/fitlife

# --- Auth (Phase 4) ---
# JWT_SECRET_KEY=change-me
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
